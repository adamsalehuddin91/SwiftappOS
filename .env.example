# PostgreSQL connection string
# For Coolify internal: postgresql://user:password@db-container-name:5432/dbname
# For Neon: postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://swiftappos:password@swiftappos-db:5432/swiftappos"

# Auth password (set this to protect access in production)
SWIFTAPP_PASSWORD="your-secure-password-here"
